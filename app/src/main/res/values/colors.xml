<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Cosmic Theme Colors based on Nebula theme -->
    
    <!-- Background Colors -->
    <color name="cosmic_black">#0A0A0A</color>
    <color name="cosmic_navy">#121826</color>
    <color name="cosmic_dark_gray">#1A1D29</color>
    
    <!-- Primary Accent Colors -->
    <color name="cosmic_blue">#3A86FF</color>
    <color name="cosmic_purple">#9D4EDD</color>
    
    <!-- Text Colors -->
    <color name="cosmic_white">#FFFFFF</color>
    <color name="cosmic_gray">#A0A0A0</color>
    <color name="cosmic_muted">#6B7280</color>
    
    <!-- Status Colors -->
    <color name="cosmic_online">#10B981</color>
    <color name="cosmic_away">#F59E0B</color>
    <color name="cosmic_busy">#EF4444</color>
    <color name="cosmic_offline">#6B7280</color>
    
    <!-- Gradient Colors -->
    <color name="cosmic_gradient_start">#3A86FF</color>
    <color name="cosmic_gradient_end">#9D4EDD</color>
    
    <!-- Card and Surface Colors -->
    <color name="cosmic_card">#1E293B</color>
    <color name="cosmic_surface">#334155</color>
    <color name="cosmic_border">#475569</color>
    
    <!-- Button Colors -->
    <color name="cosmic_button_primary">#3A86FF</color>
    <color name="cosmic_button_secondary">#9D4EDD</color>
    <color name="cosmic_button_danger">#EF4444</color>
    
    <!-- Input Colors -->
    <color name="cosmic_input_background">#1E293B</color>
    <color name="cosmic_input_border">#475569</color>
    <color name="cosmic_input_focus">#3A86FF</color>
    
    <!-- Transparency Colors -->
    <color name="cosmic_black_50">#800A0A0A</color>
    <color name="cosmic_black_80">#CC0A0A0A</color>
    <color name="cosmic_blue_20">#333A86FF</color>
    <color name="cosmic_purple_20">#339D4EDD</color>
    
    <!-- System Colors -->
    <color name="colorPrimary">@color/cosmic_blue</color>
    <color name="colorPrimaryVariant">@color/cosmic_purple</color>
    <color name="colorOnPrimary">@color/cosmic_white</color>
    <color name="colorSecondary">@color/cosmic_purple</color>
    <color name="colorSecondaryVariant">@color/cosmic_blue</color>
    <color name="colorOnSecondary">@color/cosmic_white</color>
    <color name="colorBackground">@color/cosmic_black</color>
    <color name="colorOnBackground">@color/cosmic_white</color>
    <color name="colorSurface">@color/cosmic_navy</color>
    <color name="colorOnSurface">@color/cosmic_white</color>
    <color name="colorError">#EF4444</color>
    <color name="colorOnError">@color/cosmic_white</color>
</resources>