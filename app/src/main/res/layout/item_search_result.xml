<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="?attr/selectableItemBackground"
    android:clickable="true"
    android:focusable="true"
    android:padding="@dimen/spacing_md">

    <!-- Message Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="@dimen/spacing_xs">

        <ImageView
            android:id="@+id/authorAvatar"
            android:layout_width="20dp"
            android:layout_height="20dp"
            android:layout_marginEnd="@dimen/spacing_sm"
            android:src="@drawable/ic_person"
            app:tint="@color/cosmic_accent"
            android:background="@drawable/avatar_background" />

        <TextView
            android:id="@+id/authorName"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="CosmicExplorer"
            android:textColor="@color/cosmic_white"
            android:textSize="@dimen/text_size_sm"
            android:textStyle="bold"
            android:fontFamily="sans-serif-medium" />

        <TextView
            android:id="@+id/messageTime"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="2 hours ago"
            android:textColor="@color/cosmic_gray"
            android:textSize="@dimen/text_size_xs" />

    </LinearLayout>

    <!-- Message Content -->
    <TextView
        android:id="@+id/messageContent"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="This is a sample message that contains the search term"
        android:textColor="@color/cosmic_text_primary"
        android:textSize="@dimen/text_size_md"
        android:lineSpacingExtra="2dp"
        android:layout_marginStart="32dp" />

    <!-- Channel Info -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginTop="@dimen/spacing_xs"
        android:layout_marginStart="32dp">

        <ImageView
            android:layout_width="12dp"
            android:layout_height="12dp"
            android:layout_marginEnd="@dimen/spacing_xs"
            android:src="@drawable/ic_hash"
            app:tint="@color/cosmic_gray" />

        <TextView
            android:id="@+id/channelName"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="general"
            android:textColor="@color/cosmic_gray"
            android:textSize="@dimen/text_size_xs" />

    </LinearLayout>

</LinearLayout>