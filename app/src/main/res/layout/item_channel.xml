<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="@dimen/channel_item_height"
    android:background="?attr/selectableItemBackground"
    android:clickable="true"
    android:focusable="true">

    <!-- Selection border indicator -->
    <View
        android:id="@+id/selectionBorder"
        android:layout_width="2dp"
        android:layout_height="match_parent"
        android:layout_alignParentStart="true"
        android:background="@color/cosmic_blue"
        android:visibility="gone" />

    <!-- Channel content container -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="horizontal"
        android:paddingStart="@dimen/spacing_md"
        android:paddingEnd="@dimen/spacing_md"
        android:paddingTop="@dimen/spacing_xs"
        android:paddingBottom="@dimen/spacing_xs"
        android:gravity="center_vertical">

        <ImageView
            android:id="@+id/channelIcon"
            android:layout_width="20dp"
            android:layout_height="20dp"
            android:layout_marginEnd="@dimen/spacing_sm"
            android:src="@drawable/ic_hash"
            app:tint="@color/cosmic_gray"
            android:contentDescription="@string/cd_channel_icon" />

        <TextView
            android:id="@+id/channelName"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="general"
            android:textColor="@color/cosmic_text_secondary"
            android:textSize="@dimen/text_size_md"
            android:fontFamily="sans-serif-medium" />

        <!-- Notification indicator -->
        <View
            android:id="@+id/notificationIndicator"
            android:layout_width="8dp"
            android:layout_height="8dp"
            android:background="@drawable/cosmic_dot"
            android:backgroundTint="@color/cosmic_accent"
            android:visibility="gone" />

    </LinearLayout>

</RelativeLayout>