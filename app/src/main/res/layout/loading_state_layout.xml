<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:gravity="center"
    android:background="@color/cosmic_black"
    android:padding="@dimen/spacing_xl">

    <!-- Loading Animation -->
    <ProgressBar
        android:id="@+id/loadingProgressBar"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:layout_marginBottom="@dimen/spacing_lg"
        android:indeterminateTint="@color/cosmic_accent"
        style="?android:attr/progressBarStyle" />

    <!-- Loading Title -->
    <TextView
        android:id="@+id/loadingTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/loading"
        android:textColor="@color/cosmic_white"
        android:textSize="@dimen/text_size_lg"
        android:textStyle="bold"
        android:fontFamily="sans-serif-medium"
        android:gravity="center"
        android:layout_marginBottom="@dimen/spacing_sm" />

    <!-- Loading Message -->
    <TextView
        android:id="@+id/loadingMessage"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/loading_cosmic"
        android:textColor="@color/cosmic_gray"
        android:textSize="@dimen/text_size_md"
        android:fontFamily="sans-serif"
        android:gravity="center" />
    
    <!-- Status Text for detailed loading info -->
    <TextView
        android:id="@+id/loadingStatusText"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/spacing_sm"
        android:textColor="@color/cosmic_gray_light"
        android:textSize="@dimen/text_size_sm"
        android:fontFamily="sans-serif"
        android:gravity="center"
        android:visibility="gone" />

</LinearLayout>