<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:paddingStart="@dimen/spacing_md"
    android:paddingEnd="@dimen/spacing_md"
    android:paddingTop="@dimen/spacing_lg"
    android:paddingBottom="@dimen/spacing_sm"
    android:gravity="center_vertical">

    <TextView
        android:id="@+id/headerText"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:text="TEXT CHANNELS"
        android:textColor="@color/cosmic_text_tertiary"
        android:textSize="@dimen/text_size_xs"
        android:textStyle="bold"
        android:letterSpacing="0.1"
        android:fontFamily="sans-serif-medium"
        android:textAllCaps="true" />

    <ImageView
        android:id="@+id/settingsIcon"
        android:layout_width="16dp"
        android:layout_height="16dp"
        android:src="@drawable/ic_settings"
        android:tint="@color/cosmic_text_tertiary"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:clickable="true"
        android:focusable="true"
        android:contentDescription="@string/cd_settings" />

</LinearLayout>