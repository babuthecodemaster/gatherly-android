<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:padding="16dp"
    android:background="@color/cosmic_surface"
    android:gravity="center"
    android:visibility="gone">

    <!-- Mute Button -->
    <ImageButton
        android:id="@+id/btnMute"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:layout_marginEnd="16dp"
        android:background="@drawable/voice_control_button_background"
        android:src="@drawable/ic_mic"
        android:contentDescription="@string/mute_microphone"
        android:scaleType="centerInside"
        app:tint="@color/cosmic_text_primary" />

    <!-- Deafen Button -->
    <ImageButton
        android:id="@+id/btnDeafen"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:layout_marginEnd="16dp"
        android:background="@drawable/voice_control_button_background"
        android:src="@drawable/ic_headphones"
        android:contentDescription="@string/deafen_audio"
        android:scaleType="centerInside"
        app:tint="@color/cosmic_text_primary" />

    <!-- Disconnect Button -->
    <ImageButton
        android:id="@+id/btnDisconnect"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:background="@drawable/voice_control_button_background"
        android:src="@drawable/ic_phone_hangup"
        android:contentDescription="@string/disconnect_voice"
        android:scaleType="centerInside"
        app:tint="@color/cosmic_red" />

    <!-- Connection Quality Indicator -->
    <View
        android:id="@+id/connectionQualityIndicator"
        android:layout_width="8dp"
        android:layout_height="8dp"
        android:layout_marginStart="16dp"
        android:background="@drawable/connection_quality_indicator"
        android:visibility="visible" />

</LinearLayout>