<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:padding="@dimen/message_padding"
    android:gravity="center_vertical">

    <!-- Avatar Placeholder -->
    <View
        android:layout_width="@dimen/message_avatar_size"
        android:layout_height="@dimen/message_avatar_size"
        android:layout_marginEnd="@dimen/spacing_md"
        android:background="@drawable/bg_avatar_circle"
        android:backgroundTint="@color/cosmic_gray" />

    <!-- Message Content Placeholder -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical">

        <!-- Username Placeholder -->
        <View
            android:layout_width="120dp"
            android:layout_height="16dp"
            android:layout_marginBottom="@dimen/spacing_xs"
            android:background="@drawable/cosmic_input_background"
            android:backgroundTint="@color/cosmic_gray" />

        <!-- Message Text Placeholder -->
        <View
            android:layout_width="match_parent"
            android:layout_height="14dp"
            android:layout_marginBottom="@dimen/spacing_xs"
            android:background="@drawable/cosmic_input_background"
            android:backgroundTint="@color/cosmic_gray" />

        <View
            android:layout_width="200dp"
            android:layout_height="14dp"
            android:background="@drawable/cosmic_input_background"
            android:backgroundTint="@color/cosmic_gray" />

    </LinearLayout>

</LinearLayout>