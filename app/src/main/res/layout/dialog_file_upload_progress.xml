<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@drawable/cosmic_dialog_background"
    android:padding="@dimen/spacing_lg">

    <!-- Dialog Title -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Uploading File"
        android:textColor="@color/cosmic_text_primary"
        android:textSize="@dimen/text_size_lg"
        android:textStyle="bold"
        android:fontFamily="sans-serif-medium"
        android:gravity="center"
        android:layout_marginBottom="@dimen/spacing_lg" />

    <!-- File Icon -->
    <ImageView
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:layout_gravity="center"
        android:src="@drawable/ic_upload"
        app:tint="@color/cosmic_accent"
        android:layout_marginBottom="@dimen/spacing_md"
        android:contentDescription="@string/upload_file" />

    <!-- File Name -->
    <TextView
        android:id="@+id/fileNameText"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="document.pdf"
        android:textColor="@color/cosmic_text_primary"
        android:textSize="@dimen/text_size_md"
        android:textStyle="bold"
        android:fontFamily="sans-serif-medium"
        android:gravity="center"
        android:maxLines="2"
        android:ellipsize="middle"
        android:layout_marginBottom="@dimen/spacing_sm" />

    <!-- File Size -->
    <TextView
        android:id="@+id/fileSizeText"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="2.5 MB"
        android:textColor="@color/cosmic_text_secondary"
        android:textSize="@dimen/text_size_sm"
        android:fontFamily="sans-serif"
        android:gravity="center"
        android:layout_marginBottom="@dimen/spacing_lg" />

    <!-- Progress Bar -->
    <ProgressBar
        android:id="@+id/progressBar"
        style="?android:attr/progressBarStyleHorizontal"
        android:layout_width="match_parent"
        android:layout_height="8dp"
        android:layout_marginBottom="@dimen/spacing_sm"
        android:progressTint="@color/cosmic_accent"
        android:progressBackgroundTint="@color/cosmic_surface"
        android:max="100"
        android:progress="0" />

    <!-- Progress Text -->
    <TextView
        android:id="@+id/progressText"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="0%"
        android:textColor="@color/cosmic_text_secondary"
        android:textSize="@dimen/text_size_sm"
        android:fontFamily="sans-serif"
        android:gravity="center"
        android:layout_marginBottom="@dimen/spacing_sm" />
    
    <!-- Status Text -->
    <TextView
        android:id="@+id/statusText"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/uploading_file"
        android:textColor="@color/cosmic_text_secondary"
        android:textSize="@dimen/text_size_sm"
        android:fontFamily="sans-serif"
        android:gravity="center"
        android:layout_marginBottom="@dimen/spacing_lg" />

    <!-- Error State -->
    <LinearLayout
        android:id="@+id/errorStateLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:visibility="gone"
        android:layout_marginBottom="@dimen/spacing_lg">

        <ImageView
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:layout_gravity="center"
            android:src="@drawable/ic_error"
            app:tint="@color/cosmic_red"
            android:layout_marginBottom="@dimen/spacing_sm"
            android:contentDescription="@string/upload_error" />

        <TextView
            android:id="@+id/errorMessageText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/upload_failed"
            android:textColor="@color/cosmic_red"
            android:textSize="@dimen/text_size_sm"
            android:fontFamily="sans-serif"
            android:gravity="center"
            android:layout_marginBottom="@dimen/spacing_md" />

    </LinearLayout>

    <!-- Success State -->
    <LinearLayout
        android:id="@+id/successStateLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:visibility="gone"
        android:layout_marginBottom="@dimen/spacing_lg">

        <ImageView
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:layout_gravity="center"
            android:src="@drawable/ic_check_circle"
            app:tint="@color/cosmic_green"
            android:layout_marginBottom="@dimen/spacing_sm"
            android:contentDescription="@string/upload_success" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/upload_success"
            android:textColor="@color/cosmic_green"
            android:textSize="@dimen/text_size_sm"
            android:fontFamily="sans-serif"
            android:gravity="center" />

    </LinearLayout>

    <!-- Action Buttons -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center">

        <!-- Cancel/Close Button -->
        <Button
            android:id="@+id/cancelButton"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/cancel_upload"
            android:textColor="@color/cosmic_white"
            android:textSize="@dimen/text_size_md"
            android:textStyle="bold"
            android:fontFamily="sans-serif-medium"
            android:background="@drawable/cosmic_input_background"
            android:backgroundTint="@color/cosmic_red"
            android:padding="@dimen/spacing_md"
            android:layout_marginEnd="@dimen/spacing_sm"
            style="@style/Widget.Material3.Button" />

        <!-- Retry Button -->
        <Button
            android:id="@+id/retryButton"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/retry"
            android:textColor="@color/cosmic_white"
            android:textSize="@dimen/text_size_md"
            android:textStyle="bold"
            android:fontFamily="sans-serif-medium"
            android:background="@drawable/cosmic_button_background"
            android:backgroundTint="@color/cosmic_accent"
            android:padding="@dimen/spacing_md"
            android:layout_marginStart="@dimen/spacing_sm"
            android:visibility="gone"
            style="@style/Widget.Material3.Button" />

    </LinearLayout>

</LinearLayout>