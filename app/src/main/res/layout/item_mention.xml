<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:padding="@dimen/spacing_md"
    android:background="?attr/selectableItemBackground"
    android:clickable="true"
    android:focusable="true">

    <!-- Unread Indicator -->
    <View
        android:id="@+id/unreadIndicator"
        android:layout_width="4dp"
        android:layout_height="match_parent"
        android:layout_marginEnd="@dimen/spacing_md"
        android:background="@color/cosmic_accent"
        android:visibility="visible" />

    <!-- Content -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical">

        <!-- Header with channel and time -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="@dimen/spacing_xs">

            <ImageView
                android:layout_width="16dp"
                android:layout_height="16dp"
                android:layout_marginEnd="@dimen/spacing_xs"
                android:src="@drawable/ic_hash"
                app:tint="@color/cosmic_gray" />

            <TextView
                android:id="@+id/channelNameText"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="general"
                android:textColor="@color/cosmic_accent"
                android:textSize="@dimen/text_size_sm"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/timeText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="2h ago"
                android:textColor="@color/cosmic_text_tertiary"
                android:textSize="@dimen/text_size_xs" />

        </LinearLayout>

        <!-- Author -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="@dimen/spacing_xs">

            <ImageView
                android:id="@+id/authorAvatar"
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:layout_marginEnd="@dimen/spacing_sm"
                android:src="@drawable/ic_person"
                app:tint="@color/cosmic_white"
                android:background="@drawable/bg_avatar_circle" />

            <TextView
                android:id="@+id/authorNameText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="CosmicExplorer"
                android:textColor="@color/cosmic_white"
                android:textSize="@dimen/text_size_sm"
                android:textStyle="bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="@dimen/spacing_xs"
                android:text="mentioned you:"
                android:textColor="@color/cosmic_gray"
                android:textSize="@dimen/text_size_sm" />

        </LinearLayout>

        <!-- Message Content -->
        <TextView
            android:id="@+id/messageContentText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Hey @you, welcome to the cosmic gaming hub! 🚀"
            android:textColor="@color/cosmic_text_secondary"
            android:textSize="@dimen/text_size_md"
            android:lineSpacingExtra="2dp"
            android:maxLines="3"
            android:ellipsize="end" />

    </LinearLayout>

    <!-- Action Button -->
    <ImageView
        android:id="@+id/jumpToMessageButton"
        android:layout_width="@dimen/touch_target_small"
        android:layout_height="@dimen/touch_target_small"
        android:layout_marginStart="@dimen/spacing_sm"
        android:src="@drawable/ic_arrow_forward"
        app:tint="@color/cosmic_gray"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:clickable="true"
        android:focusable="true"
        android:contentDescription="@string/jump_to_message" />

</LinearLayout>