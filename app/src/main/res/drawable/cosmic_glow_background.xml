<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape android:shape="rectangle">
            <solid android:color="@color/cosmic_navy" />
            <corners android:radius="@dimen/radius_lg" />
            <stroke
                android:width="1dp"
                android:color="@color/cosmic_blue_20" />
        </shape>
    </item>
    <item android:top="1dp" android:bottom="1dp" android:left="1dp" android:right="1dp">
        <shape android:shape="rectangle">
            <gradient
                android:angle="135"
                android:startColor="@color/cosmic_blue_20"
                android:endColor="@color/cosmic_purple_20"
                android:type="linear" />
            <corners android:radius="@dimen/radius_md" />
        </shape>
    </item>
</layer-list>